{
  "name": "valitype",
  "description": "Zero-dependency environment variable and runtime config validation for TypeScript and JavaScript.",
  "version": "2.0.2",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Samuel Fontebasso",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "build:umd": "node build.umd.mjs",
    "build:watch": "tsc --watch",
    "dev:test": "vitest",
    "docs": "typedoc",
    "format": "prettier --write ./src ./tests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "directories": {
    "test": "tests"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fontebasso/valitype.git"
  },
  "bugs": {
    "url": "https://github.com/fontebasso/valitype/issues"
  },
  "homepage": "https://github.com/fontebasso/valitype#readme",
  "unpkg": "dist/valitype.umd.js",
  "keywords": [
    "typescript",
    "javascript",
    "validation",
    "validator",
    "env",
    "environment",
    "environment-variables",
    "process-env",
    "config",
    "runtime-config",
    "runtime-validation",
    "zero-dependency",
    "zod-alternative",
    "joi-alternative",
    "yup-alternative"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
